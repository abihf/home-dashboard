    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "systeminformation": "^5.31.5",
    "tailwindcss": "^4.2.2",
    "vite": "npm:@voidzero-dev/vite-plus-core",
    "vite-plus": "^0.1.16"
