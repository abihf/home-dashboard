		"svelte-check": "^4.4.6",
		"systeminformation": "^5.31.5",
		"tailwindcss": "^4.2.2",
		"vite": "npm:@voidzero-dev/vite-plus-core",
		"vite-plus": "^0.1.16"
	},
	"type": "module",
	"dependencies": {
		"@types/bun": "^1.3.12",
		"svelte-adapter-bun": "^1.0.1"
